# ============================================================================
#  .env.example  —  Modelo de configuração do laboratório
# ============================================================================
#  Copie este arquivo para ".env" e ajuste se necessário:
#     Windows (PowerShell):  Copy-Item .env.example .env
#     Linux/Mac:             cp .env.example .env
#
#  As DUAS apps leem este mesmo .env (na raiz do projeto).
#  Os valores abaixo já batem com o docker-compose.yml e o least_privilege.sql.
# ============================================================================

# ---- Conexão com o banco (host/porta valem para as duas apps) --------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sqli_lab

# ---- App VULNERÁVEL (porta 3000) -------------------------------------------
# De propósito conecta como 'root' (privilégio máximo) para mostrar o pior
# cenário: um usuário poderoso + query concatenada = estrago total.
DB_VULN_USER=root
DB_VULN_PASSWORD=root_lab_senha
PORT_VULN=3000

# ---- App SEGURA (porta 3001) -----------------------------------------------
# Usa o usuário restrito criado em db/least_privilege.sql (só SELECT).
DB_SEGURO_USER=app_seguro
DB_SEGURO_PASSWORD=senha_app_seguro
PORT_SEGURO=3001
