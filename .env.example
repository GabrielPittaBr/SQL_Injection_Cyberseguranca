# .env.example — copie para ".env" e ajuste.
#   Windows (PowerShell):  Copy-Item .env.example .env
#   Linux / macOS:         cp .env.example .env
# As duas apps leem este mesmo .env (na raiz do projeto).

# ---- Conexão com o MySQL (host/porta valem para as duas apps) ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sqli_lab

# ---- App VULNERÁVEL (porta 3000) ----
# Conecta como 'root' de propósito (privilégio máximo = pior cenário).
# Use o usuário/senha do SEU MySQL local.
DB_VULN_USER=root
DB_VULN_PASSWORD=SUA_SENHA_DO_ROOT
PORT_VULN=3000

# ---- App SEGURA (porta 3001) ----
# Usuário restrito criado por db/least_privilege.sql (só SELECT).
DB_SEGURO_USER=app_seguro
DB_SEGURO_PASSWORD=senha_app_seguro
PORT_SEGURO=3001
